# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=postgres

# Cloudflare Tunnel token (Zero Trust ingress)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Backend public API URL — the origin the BROWSER will fetch from.
#
# ⚠️  NEXT_PUBLIC_* is baked into the Next.js client bundle at BUILD time.
#     Changing this value at runtime (docker compose up -d without --build)
#     has no effect on the already-built image. After editing:
#         docker compose up -d --build web
#     The build log will print `Building with NEXT_PUBLIC_API_URL=...` —
#     verify it shows the expected value before going further.
#
# In production (HTTPS, Cloudflare Tunnel):   https://api.your-domain.com
# Local Docker Compose dev (same host):        http://localhost:3000
# Pure local dev (npm run dev):                http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------------------
# Network Routing Guide (Zero-Trust model)
#
# All services communicate through Docker's internal network using service names.
# No host ports are exposed — all inbound traffic flows through the Cloudflare Tunnel.
#
# Inter-container communication:
#   db:5432          — PostgreSQL
#   server:3000      — Rust backend
#   web:3001         — Next.js frontend
#
# Cloudflare Tunnel routing (set up in Cloudflare Zero Trust dashboard):
#   Frontend domain  → http://web:3001    (user dashboard access)
#   API domain       → http://server:3000 (agent metric ingestion)
# ------------------------------------------------------------------------------------------
