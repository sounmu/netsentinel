# ═════════════════════════════════════════════════════════════════════
# Local `cargo run` only.
#
#   ⚠️  Docker Compose does NOT read this file. The repo-root `.env`
#      is the single source of truth for containerised installs.
#      (docker-compose.yml sets `env_file: .env`.)
#
# Use this file when you are iterating on the server with
# `cargo run` against a locally-running Postgres (or a dev Postgres
# inside the compose stack reached via `127.0.0.1:5432` if you expose
# the port in a compose override).
# ═════════════════════════════════════════════════════════════════════

# PostgreSQL connection string — point at your local DB.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/netsentinel

# HS256 JWT secret. Must match every agent's .env. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_hex_string

# ── Optional for `cargo run` dev ─────────────────────────────────────
#
# Defaults below are what the server assumes when the key is absent.
# Uncomment + tweak only what you need to change.

# ALLOWED_ORIGINS=http://localhost:3001
# COOKIE_SECURE=false            # set to false for plain-HTTP localhost dev
# SCRAPE_INTERVAL_SECS=10        # fallback when a host row has no valid value
# MAX_DB_CONNECTIONS=10
# DB_STATEMENT_TIMEOUT_SECS=30
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_SECS=300
# API_RATE_LIMIT_MAX=200
# API_RATE_LIMIT_WINDOW_SECS=60
# METRICS_CACHE_MAX_ENTRIES=200
# METRICS_TOKEN=                 # bearer token for /metrics Prometheus endpoint
# ALLOW_UNAUTHENTICATED_METRICS=true
# TRUSTED_PROXY_COUNT=0
# SERVER_HOST=0.0.0.0
# SERVER_PORT=3000
