# Port this agent listens on (default: 9101)
AGENT_PORT=9101

# Bind address. 0.0.0.0 listens on every interface; use a Tailscale IP
# such as 100.x.y.z if you want the agent reachable only over Tailscale.
AGENT_BIND=0.0.0.0

# Agent auth secret. New installs receive this from the server's Add Agent
# enrollment command. Legacy/manual installs can still set JWT_SECRET.
AGENT_AUTH_SECRET=
JWT_SECRET=

# Docker metrics collection:
# - auto: collect when Docker is reachable; otherwise keep OS metrics running quietly
# - enabled: Docker is expected; connection failures stay visible in logs
# - disabled: do not connect to Docker at all
DOCKER_METRICS_MODE=auto
